generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ── Perfil de usuario (extiende auth.users de Supabase) ──────────────────────
model Profile {
  id        String   @id @default(uuid())
  username  String?  @unique
  fullName  String?  @map("full_name")
  avatarUrl String?  @map("avatar_url")
  bio       String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  progress UserProgress[]

  @@map("profiles")
}

// ── Curso ────────────────────────────────────────────────────────────────────
model Course {
  id              String   @id @default(uuid())
  slug            String   @unique
  title           String
  description     String
  thumbnail       String
  category        String   // data-engineering | cloud | machine-learning | etc.
  level           String   // principiante | intermedio | avanzado
  durationMinutes Int      @default(0) @map("duration_minutes")
  isPublished     Boolean  @default(false) @map("is_published")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  lessons Lesson[]

  @@map("courses")
}

// ── Lección ──────────────────────────────────────────────────────────────────
model Lesson {
  id              String   @id @default(uuid())
  courseId        String   @map("course_id")
  title           String
  description     String
  youtubeId       String   @map("youtube_id")
  durationSeconds Int      @default(0) @map("duration_seconds")
  orderIndex      Int      @default(0) @map("order_index")
  isPublished     Boolean  @default(false) @map("is_published")
  createdAt       DateTime @default(now()) @map("created_at")

  course   Course         @relation(fields: [courseId], references: [id], onDelete: Cascade)
  progress UserProgress[]

  @@map("lessons")
}

// ── Progreso de usuario ───────────────────────────────────────────────────────
model UserProgress {
  id          String    @id @default(uuid())
  userId      String    @map("user_id")
  lessonId    String    @map("lesson_id")
  completed   Boolean   @default(false)
  completedAt DateTime? @map("completed_at")

  profile Profile @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson  Lesson  @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@map("user_progress")
}

// ── Suscriptores (coming soon) ────────────────────────────────────────────────
model Subscriber {
  id        String   @id @default(uuid())
  email     String   @unique
  createdAt DateTime @default(now()) @map("created_at")

  @@map("subscribers")
}
